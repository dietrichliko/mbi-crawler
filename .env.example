# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# Variable names here must match the auth.username_env / auth.password_env
# fields in config/sites/*.yaml.

# --- MBI WikiJS (wiki.mbi.oeaw.ac.at) ---
# OEAW SSO credentials.  Required when wiki_mbi is enabled.
WIKI_USERNAME=your@eoeaw.ac.at
WIKI_PASSWORD=
