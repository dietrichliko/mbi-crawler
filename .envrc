# Create virtual environment if it doesn't exist
if [ ! -d ".venv" ]; then
    uv venv
fi

# Sync dependencies (including the dev group).
# Use --frozen when a lock file exists to respect it exactly;
# otherwise let uv generate/update the lock file.
if [ -f "uv.lock" ]; then
    uv sync --frozen --group dev
else
    uv sync --group dev
fi

# Activate the virtual environment for this direnv shell
source .venv/bin/activate
